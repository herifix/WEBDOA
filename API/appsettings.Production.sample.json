{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True"
  },
  "Runtime": {
    "AspNetCoreUrls": "http://0.0.0.0:5000",
    "PublicBaseUrl": "https://YOUR_API_HOST/api"
  },
  "VoiceStorage": {
    "Provider": "LocalServer",
    "RootPath": "D:\\SharedPublic\\birthday-pray",
    "EnvironmentFolder": "prod"
  },
  "GoogleCloud": {
    "BucketName": "YOUR_GCS_BUCKET",
    "UsePublicUrl": false,
    "SignedUrlExpiryMinutes": 15,
    "MaxUploadSizeMb": 10
  },
  "AppClient": {
    "AllowedOrigins": [
      "http://YOUR_FRONTEND_HOST",
      "https://YOUR_FRONTEND_HOST"
    ]
  },
  "WhatsAppGateway": {
    "Url": "https://YOUR_WHATSAPP_GATEWAY_URL",
    "Token": "YOUR_WHATSAPP_GATEWAY_TOKEN",
    "TemplateLanguageCode": "id",
    "TemplateLanguageFallbacks": "id_ID"
  },
  "MediaConversion": {
    "PtLogoRootPath": "wwwroot/pt",
    "DefaultLogoPath": "wwwroot/pt/LOGOGKY.png",
    "DefaultPtCode": "",
    "OutputWidth": 1280,
    "OutputHeight": 720
  }
}
